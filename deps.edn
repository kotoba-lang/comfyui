{:paths ["src"]
 ;; langchain (kotoba-lang) provides langchain.db (the Datomic-API-compatible
 ;; store backing the node cache / run history), the optional ChatModel node
 ;; pack, and langchain.jvm (the http-kit/jsonista host-fn wiring
 ;; comfyui.gateway's JVM branch uses). Only THIRD-PARTY dep by design;
 ;; comfyui.gateway's own http-kit/jsonista need is JVM-only (behind #?(:clj
 ;; ...) reader conditionals) and left for consumers to bring themselves
 ;; (every current consumer already declares them for its own server needs)
 ;; -- see the :test alias for how this repo's own tests supply them.
 :deps {org.clojure/data.json {:mvn/version "2.5.1"}
        io.github.kotoba-lang/langchain
        {:git/sha "c74e358c486bdbbed415261abe352ae73831bb8e"}
        ;; Workspace development against the UNet tensor/autograd branch.
        ;; Replace with its merged git SHA before publishing.
        io.github.kotoba-lang/num {:local/root "../num"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      ;; comfyui.gateway-test exercises the JVM :clj branch
                      http-kit/http-kit {:mvn/version "2.8.0"}
                      metosin/jsonista  {:mvn/version "0.3.11"}
                      ;; comfyui.nodes.toy-diffusion-test (ADR-2607131500
                      ;; Phase 1) exercises both single- and multi-channel
                      ;; real node functions. The workspace num dependency
                      ;; above contains tensor-async, conv2d-mc, and
                      ;; multi-head-attention.
                      }
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; local checkout for workspace development (orgs/kotoba-lang/*)
  :dev {:override-deps {io.github.kotoba-lang/langchain
                        {:local/root "../langchain"}}}
  ;; ADR-2607131500 follow-up: comfyui.nodes.toy-diffusion's Metal-backed
  ;; twin (ToyDiffusionStepMetal / execute-async), on real Metal, cross-
  ;; checked against the CPU-sync ToyDiffusionStep node's result.
  ;;   clojure -M:toy-diffusion-metal-verify && deno run --allow-all target/toy-diffusion-metal-verify.cjs
  :toy-diffusion-metal-verify
  {:extra-paths ["test"]
   :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                io.github.kotoba-lang/num
                {:git/sha "668fc55f6ff8d4afd38313d19e9cbdee83487371"}}
   :main-opts ["-m" "cljs.main"
               "-co" "{:optimizations :simple :target :nodejs :main comfyui.nodes.toy-diffusion-metal-verify :output-to \"target/toy-diffusion-metal-verify.cjs\"}"
               "-c" "comfyui.nodes.toy-diffusion-metal-verify"]}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
